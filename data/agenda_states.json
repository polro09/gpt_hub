    "1471643188744949884": {
      "guild_id": 928983859222159390,
      "channel_id": 1471643134864785428,
      "message_id": 1471643188744949884,
      "proposer_id": 257097077782216704,
      "title": "2군 외국인 길드 창설",
      "content": "2군 외국인 길드 창설",
      "created_at": "2026-02-12T23:04:35.274499+00:00",
      "deadline_at": null,
      "deadline_raw": "",
      "votes": {
        "257097077782216704": {
          "role_id": 1456634446659719271,
          "stance": "AGREE",
          "opinion": "2군 외국인 전용 길드 창설\n디스코드 권한 분리 및 이후의 이점 고려",
          "at": "2026-02-12T23:05:16.871304+00:00"
        },
        "638927161675481118": {
          "role_id": 1456635035288342671,
          "stance": "AGREE",
          "opinion": "",
          "at": "2026-02-13T00:08:01.914575+00:00"
        },
        "329597905063247873": {
          "role_id": 1456635035288342671,
          "stance": "OPPOSE",
          "opinion": "아직은 아닌거같음",
          "at": "2026-02-13T00:09:01.048149+00:00"
        },
        "164075614372888576": {
          "role_id": 1456635035288342671,
          "stance": "OPPOSE",
          "opinion": "애매흔 2길드 체제 및 컨트롤 누가 다룰 것인가가 중요, 한국인 길드 관리보다 몇배의 노력이 들어갑니다. \n한국의 경우 과금때문에 빠르게 전력으로서 합류할 수 있을 뿐, PYT 사례에서 볼 때 길갑 그냥 넣고 어영부영하다  접은 애들이 8할 이상이었음",
          "at": "2026-02-13T00:09:56.370969+00:00"
        },
        "1015118311916314674": {
          "role_id": 1456635035288342671,
          "stance": "OPPOSE",
          "opinion": "",
          "at": "2026-02-13T01:48:34.760948+00:00"
        },
        "285690280915501066": {
          "role_id": 1456635035288342671,
          "stance": "OPPOSE",
          "opinion": "동맹 길드, 혈맹 길드가 아닌 CB2군이라면 간접적이 아니라 직접적으로 모든걸 관여하고 같이 활동해야하는데 소통의 불편함이 가장 큰 장벽일것 같습니다.",
          "at": "2026-02-13T06:07:35.509154+00:00"
        },
        "179931718554353664": {
          "role_id": 1456635069157347399,
          "stance": "ABSTAIN",
          "opinion": "검증된 실력의 인원이면 나쁘지 않은데 그런애들은 안올듯 빨대충만 올것같음",
          "at": "2026-02-13T07:15:22.671311+00:00"
        },
        "359352327607549953": {
          "role_id": 1456635069157347399,
          "stance": "OPPOSE",
          "opinion": "",
          "at": "2026-02-13T07:48:26.254201+00:00"
        },
        "708689195404755004": {
          "role_id": 1456635069157347399,
          "stance": "OPPOSE",
          "opinion": "",
          "at": "2026-02-13T12:12:09.071484+00:00"
        },
        "245502114162409472": {
          "role_id": 1456635069157347399,
          "stance": "AGREE",
          "opinion": "pvp 하고자 하는 인원들이 관심있어서 cb에 가입 신청을 넣어도   cb 컨셉상 같이 할 수 없기때문에 어쩔 수 없이 내쳤다고 생각하는데 따로 창설 후 skt와 비슷한 컨셉으로 간다면 괜찮지 않을까 생각합니다.\n우리가 취약한 시간대에 전력이 보강된다 생각하면 좋을 것 같기도 합니다만 이건 희망회로고 외교적 마찰이 늘어나거나 의미없는 전력만 늘어나는 등 디메리트가 커질 가능성도 없진 않아서 저는 찬성은 하되 안건이 통과가 되지 않더라도 무방한 입장입니다.",
          "at": "2026-02-13T13:02:32.352089+00:00"
        }
      }
    },
    "1471835588746281082": {
      "guild_id": 928983859222159390,
      "channel_id": 1471835399084052614,
      "message_id": 1471835588746281082,
      "proposer_id": 164075614372888576,
      "title": "HME 협상 진행 조건",
      "content": "중앙 해역은 예외없이 들어오면 죽는다. 싸우려면 함대 갖추고와라 \n\n끝없는 바다 - DDT와 동일 조건 \n\n1)저희 지역에서 요새 공략하면 거기서 나오는 물은 저희 도시에 그냥 경매로 올려줄 것  (우리가 사갈테니)\n\n2) 디스코드 대사관 설치 및 요새를 공략하러 갈 시 저희에게 통보해주면 저희도 같이 참여하거나 필요 시 경호를 제공할 수 있다.\n(얻는 자원은 적겠지만 리스크는 줄어들 것)",
      "created_at": "2026-02-13T11:49:04.648383+00:00",
